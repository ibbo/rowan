# Copy this file to .env and fill in your actual API key
# Never commit .env to version control!

OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override database path
# SCDDB_SQLITE=data/scddb/scddb.sqlite

# Optional: Set log level for MCP server
# SCDDB_LOG_LEVEL=WARNING

# Google AI API key (for Gemini models)
# GOOGLE_API_KEY=your-google-api-key-here

# Admin password for the admin interface
ADMIN_PASSWORD=changeme

# Public support contact shown in the app footer and policy pages
# SUPPORT_EMAIL=support@example.com
# SUPPORT_URL=https://example.com/support
# DONATION_URL=https://example.com/support-chatscd

# Anonymous chat free-tier gating
# Set to false to force authentication for all chat requests
ANON_CHAT_ENABLED=true
# Daily anonymous message quota per anonymous usage fingerprint
ANON_DAILY_MESSAGE_LIMIT=5
# After daily limit is reached, return auth-required event (instead of generic error)
ANON_REQUIRE_SIGNIN_AFTER_LIMIT=true
# Burst protection fixed window (seconds)
ANON_BURST_WINDOW_SECONDS=60
# Max anonymous requests allowed in each burst window
ANON_BURST_MAX_REQUESTS=8
# Anonymous message length validation
ANON_MIN_MESSAGE_CHARS=1
ANON_MAX_MESSAGE_CHARS=1500
# Optional anonymous challenge hook for suspicious traffic (default off)
ANON_CHALLENGE_ENABLED=false
ANON_CHALLENGE_SCORE_THRESHOLD=0.7
ANON_CHALLENGE_PROVIDER=turnstile

# Observability dashboard defaults
OBS_DASHBOARD_DEFAULT_HOURS=24
# Optional estimated token pricing (USD per 1M tokens). Set to provider/model rates if desired.
OBS_ESTIMATED_INPUT_COST_PER_1M=0
OBS_ESTIMATED_OUTPUT_COST_PER_1M=0

# Simple server-side alert thresholds
ALERT_WINDOW_MINUTES=5
ALERT_ERROR_RATE_THRESHOLD=0.3
ALERT_ERROR_MIN_REQUESTS=10
ALERT_TRAFFIC_SPIKE_THRESHOLD=40
ALERT_COST_SPIKE_USD_THRESHOLD=0
ALERT_COOLDOWN_MINUTES=15

# Optional uptime check script defaults (used by scripts/health_check.py)
HEALTH_CHECK_URL=http://127.0.0.1:8000/health
HEALTH_CHECK_DB_PATH=data/chat_history.db
HEALTH_CHECK_LOG_PATH=logs/uptime_checks.log
HEALTH_CHECK_LABEL=chatscd
HEALTH_CHECK_TIMEOUT_SECONDS=10
HEALTH_CHECK_ALERT_COOLDOWN_MINUTES=30

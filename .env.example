# Copy this file to .env and fill in your actual API key
# Never commit .env to version control!

OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override database path
# SCDDB_SQLITE=data/scddb/scddb.sqlite

# Optional: Set log level for MCP server
# SCDDB_LOG_LEVEL=WARNING

# Google AI API key (for Gemini models)
# GOOGLE_API_KEY=your-google-api-key-here

# Admin password for the admin interface
ADMIN_PASSWORD=changeme

# Daily message quotas (users with their own API key are unlimited)
# DAILY_LIMIT_ANON=20
# DAILY_LIMIT_USER=50

# Optional donation link shown in the footer and quota-limit message
# DONATION_URL=https://ko-fi.com/your-page

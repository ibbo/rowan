# Copy this file to .env and fill in your actual API key
# Never commit .env to version control!

OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override database path
# SCDDB_SQLITE=data/scddb/scddb.sqlite

# Optional: Set log level for MCP server
# SCDDB_LOG_LEVEL=WARNING

# Google AI API key (for Gemini models)
# GOOGLE_API_KEY=your-google-api-key-here

# Admin password for the admin interface
ADMIN_PASSWORD=changeme

# Anonymous chat free-tier gating
# Set to false to force authentication for all chat requests
ANON_CHAT_ENABLED=true
# Daily anonymous message quota per anonymous usage fingerprint
ANON_DAILY_MESSAGE_LIMIT=5
# After daily limit is reached, return auth-required event (instead of generic error)
ANON_REQUIRE_SIGNIN_AFTER_LIMIT=true
# Burst protection fixed window (seconds)
ANON_BURST_WINDOW_SECONDS=60
# Max anonymous requests allowed in each burst window
ANON_BURST_MAX_REQUESTS=8
# Anonymous message length validation
ANON_MIN_MESSAGE_CHARS=1
ANON_MAX_MESSAGE_CHARS=1500
